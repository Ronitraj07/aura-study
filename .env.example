# Aura Study — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ─── Supabase ─────────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project → Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Groq AI (SERVER-SIDE ONLY — Vercel Edge Function) ────────────
# ⚠️  DO NOT prefix with VITE_ — this must never reach the browser bundle
# Set in: https://vercel.com/dashboard → Project → Settings → Environment Variables
# Get your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ─── Grok AI (xAI) (SERVER-SIDE ONLY — Vercel Edge Function) ────────────
# ⚠️  DO NOT prefix with VITE_ — this must never reach the browser bundle
# Set in: https://vercel.com/dashboard → Project → Settings → Environment Variables
# Get your key from: https://console.x.ai/
GROK_API_KEY=xai-your_grok_api_key_here

# ─── Gemini AI (Google) (SERVER-SIDE ONLY — Vercel Edge Function) ────────────
# ⚠️  DO NOT prefix with VITE_ — this must never reach the browser bundle
# Set in: https://vercel.com/dashboard → Project → Settings → Environment Variables
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Local dev note ─────────────────────────────────────────────────
# For local development, run: npx vercel dev
# This spins up both the Vite dev server and the Edge Functions
# together, so /api/generate resolves correctly on localhost.
# Alternatively, you can still set VITE_GROQ_API_KEY locally ONLY
# (never in production) while you migrate the hooks.
